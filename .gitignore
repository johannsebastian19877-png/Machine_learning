# *.ipynb

# =========================================================================
# Artifacts del pipeline (regenerables ejecutando los notebooks)
# =========================================================================
data/*.csv
data/*.parquet
data/*.png
data/*.json
data/*.txt
models/*.pt
models/*.zip
models/*.pkl
logs/

# Mantener directorios vacios para que el pipeline encuentre las rutas
!data/.gitkeep
!models/.gitkeep

